flowchart LR
  NB[NodeBootstrap] -->|timer| S["refreshSnapshot"]
  NB -->|file| L["Log polling"]
  S --> UI["Observable UI state"]

  style NB fill:#86efac,stroke:#15803d,stroke-width:2px,color:#14532d
  style S fill:#ffffff,stroke:#0ea5e9,stroke-width:2px,color:#0369a1
  style L fill:#fde68a,stroke:#ca8a04,stroke-width:2px,color:#a16207
  style UI fill:#ffffff,stroke:#0ea5e9,stroke-width:2px,color:#0369a1
